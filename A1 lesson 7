<!-- ═══ USEFUL VERBS ═══ -->

<section id="verbs">
  <div class="sec-label">
    <div class="sec-num">🔧</div>
    <div class="sec-tag">Useful Verbs</div>
  </div>
  <div class="card">
    <h2>Useful Verbs — To have · To visit · To do</h2>
    <div class="table-wrap">
      <table class="vtable">
        <thead><tr><th>Verb</th><th>Português</th><th>Example</th><th>Listen</th></tr></thead>
        <tbody>
          <tr><td><strong>to have</strong></td><td>ter</td><td>I have a family.</td><td><button class="speak-btn" onclick="speak('I have a family.')">🔊</button></td></tr>
          <tr><td><strong>to visit</strong></td><td>visitar</td><td>I like to visit my sister.</td><td><button class="speak-btn" onclick="speak('I like to visit my sister.')">🔊</button></td></tr>
          <tr><td><strong>to do</strong></td><td>fazer</td><td>I do my homework every day.</td><td><button class="speak-btn" onclick="speak('I do my homework every day.')">🔊</button></td></tr>
        </tbody>
      </table>
    </div>
