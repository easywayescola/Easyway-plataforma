<script>
/* ═══════════ EMAILJS ═══════════ */
const EJS_SERVICE  = 'YOUR_SERVICE_ID';
const EJS_TEMPLATE = 'YOUR_TEMPLATE_ID';
const EJS_KEY      = 'YOUR_PUBLIC_KEY';
emailjs.init(EJS_KEY);

/* ═══════════ SPEECH ═══════════ */
let voices=[], readSpeed=1, isReading=false;
function loadVoices(){ voices=window.speechSynthesis.getVoices(); }
window.speechSynthesis.onvoiceschanged=loadVoices; loadVoices();
function getUSVoice(){
  return voices.find(v=>v.lang==='en-US'&&/samantha|zira|susan|jenny|aria|kate/i.test(v.name))
      || voices.find(v=>v.lang==='en-US')
      || voices.find(v=>v.lang.startsWith('en'))
      || null;
}
function speak(text,rate){
  window.speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text);
  u.lang='en-US'; u.rate=rate||1.0; u.pitch=1.0;
  const v=getUSVoice(); if(v) u.voice=v;
  window.speechSynthesis.speak(u);
}
function setSpeed(s){ readSpeed=s; }
function readStory(){
  const txt="This is my family. I have a brother, his name is Paulo, a sister, her name is Sandra and a baby girl, her name is Samanta. I live with my parents. I love my family.";
  speak(txt, readSpeed);
}

/* ═══════════ SCORE ═══════════ */
let score=0;
function addScore(n){ score+=n; document.getElementById('scoreDisplay').textContent=score; }

/* ═══════════ EXERCISE A: Fill in ═══════════ */
function checkFill(e,input){
  if(e.key!=='Enter') return;
  const correct=input.dataset.answer.trim().toLowerCase();
  const val=input.value.trim().toLowerCase();
  const fb=input.nextElementSibling;
  if(val===correct){
    input.classList.add('correct'); input.classList.remove('wrong');
    fb.textContent='✅ Correct!'; fb.className='feedback ok';
    if(!input.dataset.scored){ input.dataset.scored='1'; addScore(1); }
  } else {
    input.classList.add('wrong'); input.classList.remove('correct');
    fb.textContent=`❌ Try again! Hint: starts with "${correct[0].toUpperCase()}"`;
    fb.className='feedback no';
  }
}

/* ═══════════ EXERCISE B: Match ═══════════ */
let selectedMatch=null, matchCorrect=0;
function selectMatch(el){
  if(el.classList.contains('matched')) return;
  if(selectedMatch===null){
    if(selectedMatch) selectedMatch.classList.remove('selected');
    selectedMatch=el; el.classList.add('selected');
  } else {
    if(el===selectedMatch){ el.classList.remove('selected'); selectedMatch=null; return; }
    if(el.dataset.col===selectedMatch.dataset.col){
      selectedMatch.classList.remove('selected'); selectedMatch=el; el.classList.add('selected'); return;
    }
    if(el.dataset.pair===selectedMatch.dataset.pair){
      el.classList.add('matched'); selectedMatch.classList.remove('selected'); selectedMatch.classList.add('matched');
      matchCorrect++; selectedMatch=null;
      document.getElementById('matchScore').textContent=`✅ ${matchCorrect}/5 matched!`;
      if(matchCorrect===5){ addScore(3); document.getElementById('matchScore').textContent='🎉 Perfect! All matched! +3 points'; }
    } else {
      el.classList.add('wrong-flash'); selectedMatch.classList.add('wrong-flash');
      setTimeout(()=>{ el.classList.remove('wrong-flash','selected'); selectedMatch&&selectedMatch.classList.remove('wrong-flash','selected'); selectedMatch=null; },600);
    }
  }
}

/* ═══════════ EXERCISE C: Quiz ═══════════ */
const quizData=[
  { q:'I _____ coffee every morning.', opts:['do coffee','have coffee','am coffee','visit coffee'], a:1, tip:'have = tomar/beber' },
  { q:'She _____ lunch at school.', opts:['does','visits','has','is'], a:2, tip:'has = 3ª pessoa de have' },
  { q:'We _____ dinner at 7pm.', opts:['do','have','visit','are'], a:1, tip:'have dinner = jantar' },
  { q:'I _____ chicken for lunch.', opts:['visit','do','have','am'], a:2, tip:'have = comer' },
];
(function buildQuiz(){
  const area=document.getElementById('quizArea');
  quizData.forEach((q,i)=>{
    const div=document.createElement('div'); div.className='quiz-item'; div.dataset.i=i;
    let html=`<div class="quiz-q">${i+1}. ${q.q}</div><div class="quiz-opts">`;
    q.opts.forEach((o,j)=>{ html+=`<button class="quiz-opt" data-qi="${i}" data-oi="${j}" onclick="pickQuiz(this)">${o}</button>`; });
    html+=`</div><div class="feedback" id="qfb${i}"></div>`;
    div.innerHTML=html; area.appendChild(div);
  });
})();
const quizAnswers={};
function pickQuiz(btn){
  const qi=btn.dataset.qi;
  document.querySelectorAll(`[data-qi="${qi}"]`).forEach(b=>{ b.classList.remove('selected'); b.style.fontWeight=''; });
  btn.classList.add('selected'); btn.style.fontWeight='700';
  quizAnswers[qi]=parseInt(btn.dataset.oi);
}
function checkQuiz(){
  let correct=0;
  quizData.forEach((q,i)=>{
    const fb=document.getElementById('qfb'+i);
    const btns=document.querySelectorAll(`[data-qi="${i}"]`);
    btns.forEach(b=>b.disabled=true);
    if(quizAnswers[i]===q.a){
      correct++;
      btns[q.a].classList.add('correct');
      fb.textContent='✅ Correct! '+q.tip; fb.className='feedback ok';
    } else {
      if(quizAnswers[i]!==undefined) btns[quizAnswers[i]].classList.add('wrong');
      btns[q.a].classList.add('correct');
      fb.textContent='❌ The answer is: '+quizData[i].opts[q.a]+' — '+q.tip; fb.className='feedback no';
    }
  });
  const res=document.getElementById('quizResult');
  res.textContent=`Result: ${correct}/${quizData.length} correct!`;
  res.style.color= correct===quizData.length ? '#27ae60' : '#c0392b';
  if(correct===quizData.length) addScore(2);
}

/* ═══════════ EXERCISE D: True/False ═══════════ */
const tfData=[
  { s:'The narrator has one brother.', answer:false, explanation:'He has a brother (Paulo), a sister (Sandra) and a baby girl (Samanta). That\'s one brother ✅ — True!' },
  { s:'The sister\'s name is Samanta.', answer:false, explanation:'Samanta is the baby girl. The sister\'s name is Sandra.' },
  { s:'The narrator lives with his/her parents.', answer:true, explanation:'Yes! "I live with my parents."' },
  { s:'His brother\'s name is Paulo.', answer:true, explanation:'Yes! "I have a brother, his name is Paulo."' },
];
(function buildTF(){
  const area=document.getElementById('tfArea');
  tfData.forEach((item,i)=>{
    const div=document.createElement('div');
    div.style.cssText='margin-bottom:14px;background:#f9f9f9;border-radius:10px;padding:12px 14px;border:1px solid var(--border)';
    div.innerHTML=`<p style="font-size:.9rem;margin-bottom:8px"><strong>${i+1}.</strong> ${item.s}</p>
      <div style="display:flex;gap:8px">
        <button class="quiz-opt" style="flex:1" data-tfi="${i}" data-val="true" onclick="pickTF(this)">✅ True</button>
        <button class="quiz-opt" style="flex:1" data-tfi="${i}" data-val="false" onclick="pickTF(this)">❌ False</button>
      </div>
      <div class="feedback" id="tffb${i}"></div>`;
    area.appendChild(div);
  });
})();
const tfAnswers={};
function pickTF(btn){
  const i=btn.dataset.tfi;
  document.querySelectorAll(`[data-tfi="${i}"]`).forEach(b=>b.style.fontWeight='');
  btn.style.fontWeight='700'; tfAnswers[i]=btn.dataset.val==='true';
}
function checkTF(){
  let correct=0;
  tfData.forEach((item,i)=>{
    const fb=document.getElementById('tffb'+i);
    const btns=document.querySelectorAll(`[data-tfi="${i}"]`);
    btns.forEach(b=>b.disabled=true);
    if(tfAnswers[i]===item.answer){
      correct++;
      fb.textContent='✅ Correct! '+item.explanation; fb.className='feedback ok';
    } else {
      fb.textContent='❌ '+item.explanation; fb.className='feedback no';
    }
  });
  const res=document.getElementById('tfResult');
  res.textContent=`Result: ${correct}/${tfData.length} correct!`;
  res.style.color=correct===tfData.length?'#27ae60':'#c0392b';
  if(correct===tfData.length) addScore(2);
}

/* ═══════════ COLLECT & SUBMIT ═══════════ */
function collectAll(){
  // Ex A
  let exA='';
  document.querySelectorAll('#exA li').forEach((li,i)=>{
    const inp=li.querySelector('.fill-input');
    const ok=inp.classList.contains('correct')?'✅':'❌';
    exA+=`${i+1}. "${inp.value||'(em branco)'}" ${ok}\n`;
  });
  // Writing
  const writing=[
    'I have: '+( document.getElementById('w1').value||'(em branco)'),
    'I always: '+(document.getElementById('w2').value||'(em branco)'),
    'I do: '+(document.getElementById('w3').value||'(em branco)'),
    'Breakfast: '+(document.getElementById('w4').value||'(em branco)'),
    'Family description: '+(document.getElementById('w5').value||'(em branco)'),
  ].join('\n');
  return { exA, writing };
}

async function submitAll(){
  const name=document.getElementById('studentName').value.trim();
  const msg=document.getElementById('submitMsg');
  const btn=document.getElementById('submitBtn');
  if(!name){ msg.textContent='⚠️ Digite seu nome antes de enviar!'; msg.style.color='#f39c12'; return; }
  const {exA,writing}=collectAll();
  btn.disabled=true; btn.textContent='⏳ Enviando...';
  msg.textContent=''; msg.style.color='#fff';
  try {
    await emailjs.send(EJS_SERVICE, EJS_TEMPLATE,{
      student_name:name, score, lesson:'Unit 2 – Daily Life – Lesson 7',
      exercise_a:exA, exercise_b:'(Match – verificar score na tela)', exercise_c:'(Quiz – verificar score na tela)',
      exercise_d:'(True/False – verificar score na tela)', writing,
      to_email:'profhesione@gmail.com'
    });
    msg.textContent='✅ Enviado com sucesso! O professor receberá tudo. Ótimo trabalho! 🎉';
    btn.textContent='✅ Enviado!';
  } catch(err){
    console.error(err);
    msg.textContent='❌ Erro ao enviar. Tente novamente.';
    msg.style.color='#ffc0c0';
    btn.disabled=false; btn.textContent='📤 Enviar Respostas';
  }
}
</script>

</body>
