<!-- ═══ LISTENING ═══ -->

<section id="listening">
  <div class="sec-label">
    <div class="sec-num">👂</div>
    <div class="sec-tag">Listening</div>
  </div>
  <div class="card">
    <h2>👂 Listening Practice</h2>
    <div class="tip">💡 Clique em 🔊 para ouvir cada frase. Repita em voz alta!</div>
    <ul class="listen-list">
      <li><span>This is my family.</span><button class="speak-btn" onclick="speak('This is my family.')">🔊</button></li>
      <li><span>I have one brother.</span><button class="speak-btn" onclick="speak('I have one brother.')">🔊</button></li>
      <li><span>I live with my parents.</span><button class="speak-btn" onclick="speak('I live with my parents.')">🔊</button></li>
      <li><span>I love my family.</span><button class="speak-btn" onclick="speak('I love my family.')">🔊</button></li>
      <li><span>I never do the laundry.</span><button class="speak-btn" onclick="speak('I never do the laundry.')">🔊</button></li>
      <li><span>I always do the dishes.</span><button class="speak-btn" onclick="speak('I always do the dishes.')">🔊</button></li>
      <li><span>I have coffee in the morning.</span><button class="speak-btn" onclick="speak('I have coffee in the morning.')">🔊</button></li>
