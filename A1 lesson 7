<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Unit 2 – Daily Life · Lesson 7 · EasyWay</title>
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<style>
:root{
  --green:#4a7c59;--gl:#e8f5e9;--gd:#2e5c3a;
  --gold:#e6a817;--goldl:#fff8e6;--goldd:#b07800;
  --blue:#2563eb;--bluel:#eff6ff;
  --red:#c0392b;--redl:#fdecea;
  --purple:#7c3aed;--purplel:#f5f3ff;
  --bg:#f9f7f2;--card:#fff;--text:#1a1a2e;--muted:#666;
  --border:#e0ddd5;--radius:14px;--shadow:0 2px 12px rgba(0,0,0,.08);
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);line-height:1.65}

header{background:var(–gd);color:#fff;padding:14px 20px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:200;box-shadow:0 2px 8px rgba(0,0,0,.25)}
.logo strong{font-size:1.05rem}.logo span{font-size:.72rem;opacity:.8;display:block}
.score-badge{margin-left:auto;background:var(–gold);color:#fff;font-weight:700;padding:5px 14px;border-radius:999px;font-size:.88rem;white-space:nowrap}

nav{background:var(–green);display:flex;overflow-x:auto;scrollbar-width:none}
nav::-webkit-scrollbar{display:none}
nav a{color:rgba(255,255,255,.85);text-decoration:none;padding:10px 14px;font-size:.78rem;white-space:nowrap;transition:background .2s}
nav a:hover{background:rgba(255,255,255,.18);color:#fff}

.hero{background:linear-gradient(135deg,var(–gd),var(–green));color:#fff;text-align:center;padding:30px 20px 22px}
.unit-tag{display:inline-block;background:rgba(255,255,255,.2);border-radius:999px;padding:3px 14px;font-size:.75rem;margin-bottom:10px}
.hero h1{font-size:1.65rem;font-weight:800}
.hero p{font-size:.86rem;opacity:.85;margin-top:6px}

main{max-width:880px;margin:0 auto;padding:24px 16px 60px}
section{margin-bottom:36px}
.sec-label{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.sec-num{background:var(–green);color:#fff;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;flex-shrink:0}
.sec-tag{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(–muted)}

.card{background:var(–card);border-radius:var(–radius);box-shadow:var(–shadow);padding:22px;border:1px solid var(–border);margin-bottom:16px}
.card h2{font-size:1.12rem;margin-bottom:14px;color:var(–gd)}
.card h3{font-size:.98rem;margin-bottom:10px;color:var(–green)}
.tip{background:var(–goldl);border-left:4px solid var(–gold);border-radius:8px;padding:11px 15px;font-size:.86rem;color:#7a5900;margin-bottom:16px}
.obs{background:var(–bluel);border-left:4px solid var(–blue);border-radius:8px;padding:11px 15px;font-size:.86rem;color:#1e40af;margin-bottom:16px}
.pron{background:var(–purplel);border-left:4px solid var(–purple);border-radius:8px;padding:11px 15px;font-size:.86rem;color:#5b21b6;margin-bottom:16px}
hr.div{border:none;border-top:1px solid var(–border);margin:20px 0}

/* VOCAB GRID */
.vocab-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:10px}
.vocab-card{background:var(–gl);border:1px solid #c8e6c9;border-radius:10px;padding:13px 12px;cursor:pointer;transition:transform .15s,box-shadow .15s;user-select:none;text-align:center}
.vocab-card:hover,.vocab-card:active{transform:scale(1.05);box-shadow:0 4px 14px rgba(74,124,89,.22)}
.vocab-card .emoji{font-size:1.6rem;margin-bottom:4px}
.vocab-card .eng{font-weight:700;font-size:.92rem}
.vocab-card .pt{font-size:.76rem;color:var(–muted);margin-top:2px}

/* VERB TABLE */
.table-wrap{overflow-x:auto}
.vtable{width:100%;border-collapse:collapse;font-size:.88rem;min-width:400px}
.vtable th{background:var(–gd);color:#fff;padding:10px 12px;text-align:left;font-weight:600}
.vtable td{padding:9px 12px;border-bottom:1px solid var(–border)}
.vtable tr:last-child td{border-bottom:none}
.vtable tr:nth-child(even) td{background:#f4fbf5}

/* SPEAK */
.speak-btn{background:none;border:1px solid #cde;cursor:pointer;font-size:1rem;padding:3px 8px;border-radius:6px;transition:background .15s,transform .1s;vertical-align:middle;margin-right:4px}
.speak-btn:hover{background:var(–gl)}
.speak-btn:active{transform:scale(.9)}

/* READING */
.reading-box{background:var(–gl);border-radius:10px;padding:18px;font-size:.95rem;line-height:1.85;margin-bottom:14px;border-left:4px solid var(–green)}
.family-img{font-size:4rem;text-align:center;padding:14px 0}

/* LISTENING */
.listen-list{list-style:none;display:flex;flex-direction:column;gap:8px}
.listen-list li{display:flex;align-items:center;gap:10px;background:#f9f9f9;border-radius:8px;padding:10px 14px;font-size:.9rem;border:1px solid var(–border)}
.listen-list li span{flex:1}

/* EXERCISES */
.ex-list{list-style:none;display:flex;flex-direction:column;gap:12px}
.ex-list li{background:#f9f9f9;border-radius:10px;padding:13px 15px;font-size:.92rem;border:1px solid var(–border)}
.fill-input{border:none;border-bottom:2px solid var(–green);background:transparent;font-size:.92rem;padding:2px 6px;width:160px;outline:none;color:var(–text);font-family:inherit}
.fill-input.correct{border-bottom-color:#27ae60;background:#e8f5e9;border-radius:4px}
.fill-input.wrong{border-bottom-color:var(–red);background:var(–redl);border-radius:4px}
.feedback{font-size:.78rem;margin-top:5px;font-weight:600}
.feedback.ok{color:#27ae60}.feedback.no{color:var(–red)}

/* MATCH */
.match-wrap{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.match-col{display:flex;flex-direction:column;gap:8px}
.match-item{background:#f0f0f0;border-radius:8px;padding:10px 13px;font-size:.88rem;cursor:pointer;border:2px solid transparent;transition:all .2s;user-select:none}
.match-item.selected{border-color:var(–blue);background:var(–bluel)}
.match-item.matched{border-color:#27ae60;background:#e8f5e9;cursor:default}
.match-item.wrong-flash{border-color:var(–red);background:var(–redl)}

/* QUIZ */
.quiz-item{margin-bottom:18px}
.quiz-q{font-weight:600;margin-bottom:8px;font-size:.92rem}
.quiz-opts{display:flex;flex-direction:column;gap:6px}
.quiz-opt{background:#f5f5f5;border:2px solid var(–border);border-radius:8px;padding:9px 14px;cursor:pointer;font-size:.88rem;transition:all .2s;text-align:left}
.quiz-opt:hover{border-color:var(–green);background:var(–gl)}
.quiz-opt.correct{border-color:#27ae60;background:#e8f5e9;color:#1a5c2a}
.quiz-opt.wrong{border-color:var(–red);background:var(–redl);color:var(–red)}
.quiz-opt:disabled{cursor:default}

/* WRITING */
.writing-input{width:100%;border:1px solid var(–border);border-radius:8px;padding:10px 13px;font-size:.92rem;font-family:inherit;resize:vertical;min-height:70px;outline:none;transition:border .2s}
.writing-input:focus{border-color:var(–green)}

/* PRON PRACTICE */
.pron-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px}
.pron-card{background:var(–purplel);border:1px solid #ddd6fe;border-radius:10px;padding:14px 10px;text-align:center;cursor:pointer;transition:transform .15s,box-shadow .15s}
.pron-card:hover,.pron-card:active{transform:scale(1.06);box-shadow:0 4px 12px rgba(124,58,237,.2)}
.pron-card .word{font-weight:700;font-size:1rem;color:var(–purple)}
.pron-card .phonetic{font-size:.78rem;color:var(–muted);margin-top:3px}

/* SPEAKING */
.conv-box{background:var(–gl);border-radius:10px;padding:16px 18px;font-size:.92rem;line-height:1.9}
.conv-a{color:var(–gd);font-weight:600}
.conv-b{color:var(–blue);font-weight:600}

/* SUBMIT */
.submit-card{background:linear-gradient(135deg,var(–gd),var(–green));color:#fff;border-radius:var(–radius);padding:28px 22px;text-align:center;box-shadow:var(–shadow)}
.submit-card h2{font-size:1.15rem;margin-bottom:8px}
.submit-card p{font-size:.86rem;opacity:.88;margin-bottom:18px}
.name-input{width:100%;max-width:320px;padding:11px 16px;border-radius:10px;border:none;font-size:1rem;margin-bottom:14px;outline:none;text-align:center;color:var(–text)}
.submit-btn{background:var(–gold);color:#fff;border:none;padding:12px 30px;border-radius:999px;cursor:pointer;font-size:.95rem;font-weight:700;transition:background .2s,transform .15s;display:inline-flex;align-items:center;gap:8px}
.submit-btn:hover{background:var(–goldd);transform:scale(1.03)}
.submit-btn:disabled{opacity:.6;cursor:not-allowed;transform:none}
.submit-msg{margin-top:12px;font-size:.88rem;min-height:22px}

footer{background:var(–gd);color:rgba(255,255,255,.7);text-align:center;padding:18px;font-size:.78rem}

@media(max-width:520px){
.hero h1{font-size:1.3rem}
.card{padding:14px}
.match-wrap{grid-template-columns:1fr}
.vocab-grid{grid-template-columns:repeat(2,1fr)}
}
</style>

</head>
